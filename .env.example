# Required
AWS_REGION=us-east-1
STACK_NAME=noaa-radar

# Optional overrides (defaults shown)
# INSTANCE_TYPE=t4g.small       # EC2 instance type (ARM64 recommended)
# TILE_ZOOM=2-7                 # gdal2tiles zoom range; wider = slower & more storage
# RETENTION_MINUTES=240         # rolling tile history (4 h); minimum meaningful is ~30
# CRON_EVERY_MINUTES=5          # how often to fetch MRMS (matches NOAA cadence)

# SSH access (leave blank to use SSM Session Manager instead — recommended)
# KEY_NAME=my-ec2-keypair       # name of an existing EC2 key pair in this region
# SSH_CIDR=0.0.0.0/0            # restrict SSH ingress; e.g. 203.0.113.0/24
