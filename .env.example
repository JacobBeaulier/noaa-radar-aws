# Required
AWS_REGION=           # e.g. us-east-1
STACK_NAME=           # e.g. noaa-radar
REPO_URL=             # e.g. https://github.com/your-org/noaa-radar-aws.git

# Optional overrides (defaults shown)
# INSTANCE_TYPE=t4g.small       # EC2 instance type (ARM64 recommended)

# SSH access (leave blank to use SSM Session Manager instead — recommended)
# KEY_NAME=my-ec2-keypair       # name of an existing EC2 key pair in this region
# SSH_CIDR=0.0.0.0/0            # restrict SSH ingress; e.g. 203.0.113.0/24

# Auto-populated by infra.sh up — paste the output values here so local
# npm run mrms:upload / hrrr:upload work outside of EC2 as well.
# S3_RADAR_BUCKET=
# S3_FORECAST_BUCKET=
# CLOUDFRONT_RADAR_URL=
# CLOUDFRONT_FORECAST_URL=
